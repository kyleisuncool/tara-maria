# Local device testing
# ─────────────────────────────────────────────────────────────────────────────
# Comma-separated list of IPs/hostnames allowed to access the dev server from
# other devices on your network (e.g. your phone). Find your Mac's IP with:
#   ipconfig getifaddr en0
# Never commit real IPs — this file is safe to commit, .env.local is not.

ALLOWED_DEV_ORIGINS=       # e.g. 192.168.1.42

# Cal.com integration
# ─────────────────────────────────────────────────────────────────────────────
# Both variables are optional during development — the API routes automatically
# return mock availability and stub bookings when CAL_API_KEY is not set.
#
# To wire up a live Cal.com account:
#   1. Go to cal.com → Settings → Developer → API Keys → Create new key
#   2. Create one event type per session in the Cal.com dashboard
#   3. Copy each event type's numeric ID from the URL and paste into
#      src/modules/booking/config.ts → calEventTypeId
#   4. Copy the values below to .env.local (never commit .env.local)

CAL_API_KEY=

# Stripe payment integration
# ─────────────────────────────────────────────────────────────────────────────
# Payments are disabled when these keys are absent — the booking flow works
# without them. To enable payments:
#   1. Confirm pricing for each session type and update src/modules/booking/config.ts
#   2. Create a Stripe account at stripe.com
#   3. Go to Developers → API Keys in the Stripe dashboard
#   4. Use sk_test_ / pk_test_ keys in development, sk_live_ / pk_live_ in production
#   5. Add both keys here and to Netlify environment variables
#   6. NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY controls the toggle — payments are live
#      only when this key is present (adding it triggers a rebuild on Netlify)

STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
